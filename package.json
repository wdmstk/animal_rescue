{
  "name": "animal_rescue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint src tests middleware.ts next.config.ts tailwind.config.ts playwright.config.ts vitest.config.ts --ext .ts,.tsx",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "seed:test:baseline": "tsx scripts/seed-test-data.ts baseline",
    "seed:test:showcase": "tsx scripts/seed-test-data.ts showcase",
    "seed:test:reset": "tsx scripts/seed-test-data.ts reset",
    "seed:test:clear": "tsx scripts/seed-test-data.ts clear",
    "db:setup": "prisma migrate deploy && prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev && prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stripe": "^22.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "postcss": "^8.5.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
